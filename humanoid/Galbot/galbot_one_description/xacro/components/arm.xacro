<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	<xacro:property name="PI" value="3.141592653589793"/>
	<!-- collider: simple (primitives) | convex (visual mesh as collision); set on entry xacro e.g. robot.xacro -->
	<xacro:property name="collider_type" value="$(arg collider)"/>
	<!--
	  Parametric arm (same idea as Ai2Bot2Arm): name = link/joint prefix, direction = 1 (left) / -1 (right).
	  Usage: <xacro:galbot_one_arm name="left" direction="1"/>
	         <xacro:galbot_one_arm name="right" direction="-1"/>
	-->
	<xacro:macro name="galbot_one_arm" params="name direction:=1">
		<xacro:property name="prefix" value="${name}_"/>

		<link name="${prefix}base_link">
			<inertial>
				<origin xyz="${0.00056868 * direction} ${-5.0139E-06 * direction} -0.030184"/>
				<mass value="1.1015"/>
				<inertia ixx="0.00056381" ixy="${1.1123E-07 * direction}" ixz="${2.1236E-05 * direction}"
								 iyy="0.00057439" iyz="${-1.685E-07 * direction}" izz="0.00068513"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/base.glb" scale="1 ${direction} 1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<geometry>
						<cylinder length="0.091350" radius="0.044983"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/base.glb" scale="1 ${direction} 1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<link name="${prefix}link1">
			<!-- Reference direction=1 (left); visual: left was rpy Z PI (= scale -1 -1 1), right was scale 1 -1 1 → scale "${-direction} -1 1". -->
			<inertial>
				<origin xyz="${-3.49009164621467E-05 * direction} ${-0.0108339687508697 * direction} -0.00355285779638756"/>
				<mass value="1.503"/>
				<inertia ixx="0.0014148" ixy="1.786E-06" ixz="${8.6353E-07 * direction}"
								 iyy="0.001774" iyz="${-5.8604E-06 * direction}" izz="0.0011021"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link1.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<geometry>
						<cylinder length="0.068650" radius="0.044983"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link1.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint1" type="revolute">
			<origin xyz="0 0 0.076"/>
			<parent link="${prefix}base_link"/>
			<child link="${prefix}link1"/>
			<axis xyz="0 0 1"/>
			<limit effort="60" lower="-${PI}" upper="${PI}" velocity="1.5"/>
		</joint>

		<link name="${prefix}link2">
			<inertial>
				<origin xyz="${0.0011542937189659 * direction} ${0.125918427333295 * direction} 0.00403909337671848"/>
				<mass value="1.45678998733303"/>
				<inertia ixx="0.00269801896410487" ixy="4.63119567548212E-05" ixz="${1.77748665814381E-05 * direction}"
								 iyy="0.00131692955308753" iyz="${0.000382862812261171 * direction}" izz="0.00264831680492027"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link2.glb" scale="${direction} 1 1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin rpy="${PI/2} 0 0" xyz="0 -0.074 0"/>
					<geometry>
						<cylinder length="0.19825" radius="0.044983"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link2.glb" scale="${direction} 1 1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint2" type="revolute">
			<origin rpy="-${PI/2} 0 ${PI}"/>
			<parent link="${prefix}link1"/>
			<child link="${prefix}link2"/>
			<axis xyz="0 0 ${direction}"/>
			<limit effort="60" lower="${-PI/2}" upper="1.83" velocity="1.5"/>
		</joint>

		<link name="${prefix}link3">
			<inertial>
				<origin xyz="0.000352305768300032 -0.00726519320891149 -0.0216211172275835"/>
				<mass value="1.19882450635199"/>
				<inertia ixx="0.00220937810713451" ixy="-1.39043584660172E-05" ixz="1.48996603867525E-06"
								 iyy="0.00236018741531392" iyz="4.46418780437893E-05" izz="0.000843927012398976"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link3.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin xyz="0 0 -0.074"/>
					<geometry>
						<cylinder length="0.223485" radius="0.044983"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link3.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint3" type="revolute">
			<origin rpy="${PI/2} ${PI/2 * direction} 0" xyz="0 -0.35 0"/>
			<parent link="${prefix}link2"/>
			<child link="${prefix}link3"/>
			<axis xyz="0 0 1"/>
			<limit effort="30" lower="-${PI}" upper="${PI}" velocity="1.5"/>
		</joint>

		<link name="${prefix}link4">
			<inertial>
				<origin xyz="1.6053E-07 -0.0841 0.0032663"/>
				<mass value="0.86736"/>
				<inertia ixx="0.00087789" ixy="1.0686E-08" ixz="-1.4208E-07" iyy="0.00058539" iyz="-0.0001428"
								 izz="0.00082718"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link4.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin rpy="${PI/2} 0 0" xyz=" 0 -0.14  0"/>
					<geometry>
						<cylinder length="0.16085" radius="0.044983"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link4.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint4" type="revolute">
			<origin rpy="-${PI/2} 0 ${PI}"/>
			<parent link="${prefix}link3"/>
			<child link="${prefix}link4"/>
			<axis xyz="0 0 1"/>
			<limit effort="30" lower="-2.1" upper="2.1" velocity="1.5"/>
		</joint>

		<link name="${prefix}link5">
			<!-- Reference direction=1 (left); collision: left offset + r=0.034983, right origin + r=0.044983 → blend with (1±direction)/2. -->
			<inertial>
				<origin xyz="${1.5971E-06 * direction} ${-0.025642 * direction} -0.117744"/>
				<mass value="1.3926"/>
				<inertia ixx="0.00316702853902255" ixy="8.3315E-08" ixz="${1.4879E-07 * direction}"
								 iyy="0.00325737339135618" iyz="${0.000396176140685722 * direction}" izz="0.000888812918742085"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link5.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin xyz="0 -0.04 -0.08"/>
					<geometry>
						<box size="0.07 0.02 0.2"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link5.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint5" type="revolute">
			<origin rpy="${PI/2} ${PI} 0" xyz="0 -0.36 0"/>
			<parent link="${prefix}link4"/>
			<child link="${prefix}link5"/>
			<axis xyz="0 0 1"/>
			<limit effort="10" lower="-${PI}" upper="${PI}" velocity="1.5"/>
		</joint>

		<link name="${prefix}link6">
			<inertial>
				<origin xyz="-2.88922358060439E-06 -0.000979379563628591 -1.95950029232006E-05"/>
				<mass value="0.574328152865271"/>
				<inertia ixx="0.000196239414479137" ixy="-4.42040670473688E-09" ixz="-2.96256099677375E-08"
								 iyy="0.00023336393089217" iyz="-6.88062986985096E-08" izz="0.000196560460694031"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link6.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link6.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint6" type="revolute">
			<origin rpy="-${PI/2} 0 ${PI}"/>
			<parent link="${prefix}link5"/>
			<child link="${prefix}link6"/>
			<axis xyz="0 0 1"/>
			<limit effort="10" lower="-${PI/2}" upper="${PI/2}" velocity="1.5"/>
		</joint>

		<link name="${prefix}link7">
			<inertial>
				<origin xyz="0.000145324653036516 0.000669639293546548 0.0517788732710871"/>
				<mass value="0.271983892475789"/>
				<inertia ixx="9.12795880546355E-05" ixy="-3.70484062161125E-07" ixz="3.02036543797804E-07"
								 iyy="9.01051818347072E-05" iyz="-2.27095800634144E-07" izz="0.00015076316927533"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/arm/link7.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin rpy="0 0 0" xyz="0 0 0.025"/>
					<geometry>
						<cylinder length="0.12" radius="0.031"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/arm/link7.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}joint7" type="revolute">
			<origin rpy="${PI/2 * direction} ${(1 - direction) * PI/2} ${(1 - direction) * PI/2}"/>
			<parent link="${prefix}link6"/>
			<child link="${prefix}link7"/>
			<axis xyz="0 0 1"/>
			<limit effort="10" lower="-${PI}" upper="${PI}" velocity="1.5"/>
		</joint>

		<link name="${prefix}end_effector_mount_link"/>
		<joint name="${prefix}end_effector_mount_joint" type="fixed">
			<origin xyz="0 0 0.0845"/>
			<parent link="${prefix}link7"/>
			<child link="${prefix}end_effector_mount_link"/>
		</joint>

		<joint name="${prefix}flange_joint" type="fixed">
			<origin rpy="0 0 ${(1 + direction) * PI/2}"/>
			<parent link="${prefix}end_effector_mount_link"/>
			<child link="${prefix}flange_base_link"/>
		</joint>

		<link name="${prefix}flange_base_link">
			<inertial>
				<origin xyz="0.052829 -0.00096484 0.013285"/>
				<mass value="0.25733"/>
				<inertia ixx="0.0002175" ixy="-2.5433E-06" ixz="4.0586E-06" iyy="5.3894E-05" iyz="-1.8533E-06"
								 izz="0.00025319"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/flange/flange.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/flange/flange.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<link name="${prefix}flange_mount_link"/>
		<joint name="${prefix}flange_mount_joint" type="fixed">
			<origin xyz="0 0 0.006"/>
			<parent link="${prefix}flange_base_link"/>
			<child link="${prefix}flange_mount_link"/>
		</joint>

		<joint name="${prefix}camera_flange_joint" type="fixed">
			<origin rpy="${PI} -1.308996939 0" xyz="0.0526 -0.02 0.02054"/>
			<parent link="${prefix}flange_base_link"/>
			<child link="${prefix}camera_flange_link"/>
		</joint>

		<link name="${prefix}camera_flange_link">
			<inertial>
				<origin xyz="0.052829 -0.00096484 0.013285"/>
				<mass value="0.25733"/>
				<inertia ixx="0.0002175" ixy="-2.5433E-06" ixz="4.0586E-06" iyy="5.3894E-05" iyz="-1.8533E-06"
								 izz="0.00025319"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/flange/camera_support.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/flange/camera_support.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<link name="${prefix}camera_link">
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/realsense/d415.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="${prefix}camera_joint" type="fixed">
			<origin rpy="-${PI/2} 0 -${PI/2}" xyz="0.0095 -0.02 0"/>
			<parent link="${prefix}camera_flange_link"/>
			<child link="${prefix}camera_link"/>
		</joint>

	</xacro:macro>
</robot>
