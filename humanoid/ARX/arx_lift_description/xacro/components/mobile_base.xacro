<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- 包含轮子模块 -->
  <xacro:include filename="$(find arx_lift_description)/xacro/components/wheel.xacro"/>
  
  <xacro:property name="PI" value="3.1415926535897931"/>
  <xacro:macro name="MobileBase" params="enable_wheel_joints:='true'">

    <link name="base_link">
      <inertial>
        <origin xyz="0.015300075250394498 -0.0039712791148939055 0.21685783167580347"/>
        <mass value="67.7696558151508"/>
        <inertia ixx="7.900786" ixy="-0.021075" ixz="0.25289" iyy="8.068966" iyz="0.12408" izz="2.254894"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/base/base_link.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/base/base_link.obj"/>
        </geometry>
      </collision>
    </link>

    <!-- 根据enable_wheel_joints参数决定使用轮子宏还是空link -->
    <xacro:if value="${enable_wheel_joints}">
      <!-- 启用轮子关节时：使用空link -->
      <link name="wheel_1"/>
      <link name="wheel_2"/>
      <link name="wheel_3"/>
    </xacro:if>
    <xacro:unless value="${enable_wheel_joints}">
      <!-- 不启用轮子关节时：使用轮子宏创建完整的轮子link（不包含被动轮） -->
      <xacro:wheel wheel_name="wheel_1" enable_passive_wheels="false"/>
      <xacro:wheel wheel_name="wheel_2" enable_passive_wheels="false"/>
      <xacro:wheel wheel_name="wheel_3" enable_passive_wheels="false"/>
    </xacro:unless>

    <!-- 根据参数设置关节类型 -->
    <xacro:property name="wheel_joint_type" value="fixed"/>
    <xacro:if value="${enable_wheel_joints}">
      <xacro:property name="wheel_joint_type" value="continuous"/>
    </xacro:if>

    <!-- 轮子关节定义 -->
    <joint name="wheel1_joint" type="${wheel_joint_type}">
      <origin xyz="0.182349 0.315838 0.03" rpy="0.0 0.0 ${-2*PI/3}"/>
      <parent link="base_link"/>
      <child link="wheel_1"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

    <joint name="wheel2_joint" type="${wheel_joint_type}">
      <origin xyz="0.182349 -0.315838 0.03" rpy="0.0 0.0 ${2*PI/3}"/>
      <parent link="base_link"/>
      <child link="wheel_2"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

    <joint name="wheel3_joint" type="${wheel_joint_type}">
      <origin xyz="-0.364699 0.0 0.03"/>
      <parent link="base_link"/>
      <child link="wheel_3"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>
  </xacro:macro>
</robot>