<?xml version="1.0"?>
<!-- =================================================================================== -->
<!-- |    Body Description for Zerith H1                                               | -->
<!-- |    This file defines the torso (body) and head/neck links and joints             | -->
<!-- |    Parent: base_link (from chassis)                                              | -->
<!-- |    Children: body_yaw_link (connects to arms and neck)                           | -->
<!-- =================================================================================== -->
<robot name="zerith_h1_body" xmlns:xacro="http://www.ros.org/wiki/xacro">

	<!-- =================================================================================== -->
	<!-- Torso                                                                               -->
	<!-- =================================================================================== -->
	<link name="body_link1">
		<inertial>
			<origin xyz="0.11560518 0.00060964 0.12206768"/>
			<mass value="4.61714"/>
			<inertia ixx="0.00837134" ixy="9.116e-05" ixz="-0.00126268"
					iyy="0.02136748" iyz="-5.34e-06" izz="0.02010722"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link1.glb"/>
			</geometry>
		</visual>
		<collision>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link1.glb"/>
			</geometry>
		</collision>
	</link>

	<joint name="body_joint1" type="prismatic">
		<parent link="base_link"/>
		<child link="body_link1"/>
		<axis xyz="0 0 1"/>
		<limit lower="0" upper="0.8" effort="0" velocity="0"/>
	</joint>

	<link name="body_pitch_link">
		<inertial>
			<origin xyz="-0.00013249 0.00049551 0.10848426"/>
			<mass value="3.528"/>
			<inertia ixx="0.01235314" ixy="-9.38e-06" ixz="6.133e-05"
					iyy="0.01092549" iyz="0.00020606" izz="0.00739427"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link2.glb"/>
			</geometry>
		</visual>
		<collision>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link2.glb"/>
			</geometry>
		</collision>
	</link>

	<joint name="body_joint2" type="revolute">
		<origin xyz="0.1518 0 0.1275"/>
		<parent link="body_link1"/>
		<child link="body_pitch_link"/>
		<axis xyz="0 1 0"/>
		<limit lower="-0.05236" upper="1.309" effort="204" velocity="3.14"/>
	</joint>

	<link name="body_yaw_link">
		<inertial>
			<origin xyz="-0.00140951 0.00031062 0.13782806"/>
			<mass value="3.85886409"/>
			<inertia ixx="0.03623808" ixy="-3.118e-05" ixz="0.00019346"
					iyy="0.02298934" iyz="3.738e-05" izz="0.02244436"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link3.glb"/>
			</geometry>
		</visual>
		<collision>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/body_link3.glb"/>
			</geometry>
		</collision>
	</link>

	<joint name="body_joint3" type="revolute">
		<origin xyz="2.7149E-05 -0.00012105 0.1572"/>
		<parent link="body_pitch_link"/>
		<child link="body_yaw_link"/>
		<axis xyz="0 0 1"/>
		<limit lower="-1.0472" upper="1.0472" effort="204" velocity="3.14"/>
	</joint>

	<!-- =================================================================================== -->
	<!-- Head / Neck                                                                         -->
	<!-- =================================================================================== -->
	<link name="neck_yaw_link">
		<inertial>
			<origin xyz="-0.00118756 -0.00142144 0.08983028"/>
			<mass value="0.500718"/>
			<inertia ixx="0.00087672" ixy="2.99e-06" ixz="-3.24e-06"
					iyy="0.00084562" iyz="-5.84e-06" izz="0.00027146"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/head_link1.glb"/>
			</geometry>
		</visual>
		<collision>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/head_link1.glb"/>
			</geometry>
		</collision>
	</link>

	<joint name="head_joint1" type="revolute">
		<origin xyz="-2.71488271641473E-05 0.000121052292962553 0.2491"/>
		<parent link="body_yaw_link"/>
		<child link="neck_yaw_link"/>
		<axis xyz="0 0 1"/>
		<limit lower="-1.5708" upper="1.5708" effort="9" velocity="16.747"/>
	</joint>

	<link name="neck_pitch_link">
		<inertial>
			<origin xyz="0.04074346 -0.00094429 0.04406688"/>
			<mass value="0.85987615"/>
			<inertia ixx="0.00305527" ixy="-3.089e-05" ixz="0.00012776"
					iyy="0.00319256" iyz="-3.464e-05" izz="0.00271799"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/head_link2.glb"/>
			</geometry>
		</visual>
		<collision>
			<geometry>
				<mesh filename="file://$(find zerith_h1_description)/meshes/body/head_link2.glb"/>
			</geometry>
		</collision>
	</link>

	<joint name="head_joint2" type="revolute">
		<origin xyz="0 0 0.11"/>
		<parent link="neck_yaw_link"/>
		<child link="neck_pitch_link"/>
		<axis xyz="0 1 0"/>
		<limit lower="-0.7854" upper="0.5236" effort="9" velocity="16.747"/>
	</joint>

	<link name="neck_camera_link">
		<inertial>
			<origin xyz="0.02975925 8.48e-06 -0.00996785"/>
			<mass value="0.07123"/>
			<inertia ixx="6.97e-06" ixy="3e-08" ixz="1.8e-07"
					iyy="4.688e-05" iyz="-4e-08" izz="4.697e-05"/>
		</inertial>
		<visual>
			<geometry>
				<mesh filename="file://$(find sensor_models)/meshes/realsense/d435.glb"/>
			</geometry>
			<origin xyz="0.0325 0 0.005" rpy="1.5707963267949 -1.5707963267949 -0"/>
		</visual>
	</link>

	<joint name="neck_camera_joint" type="fixed">
		<origin xyz="0.0675568573382885 0.0324999999999979 -0.0363332072227294"
				rpy="-1.78023593389281 0 -1.5707963267949"/>
		<parent link="neck_pitch_link"/>
		<child link="neck_camera_link"/>
	</joint>

</robot>
