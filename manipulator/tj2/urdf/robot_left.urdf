    <collision>
      <geometry>
        <cylinder length="0.095" radius="0.045"/>
      </geometry>
      <origin xyz="0 0 0.0475" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0.025708 -0.185959 -0.006434" rpy="0 0 0"/>
      <mass value="3.08149"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <!-- Joint 5 -->
  <joint name="left_joint5" type="revolute">
    <parent link="left_link4"/>
    <child link="left_link5"/>
    <origin xyz="0 0 0.095" rpy="1.5708 0 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96706" upper="2.96706" effort="180" velocity="0.722775"/>
