<?xml version="1.0" ?>
<robot name="galbot_one_ros2_control" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="type" default="gripper"/>
  <xacro:arg name="ros2_control_hardware_type" default="mock_components"/>
  <xacro:property name="ros2_control_config_basename" value="ros2_controllers.yaml"/>

  <!-- Geometry/kinematics come from main robot xacro -->
  <xacro:include filename="$(find galbot_one_description)/xacro/robot.xacro"/>

  <!-- ros2_control interfaces (Astribot-style split) -->
  <xacro:include filename="$(find galbot_one_description)/xacro/ros2_control/galbot_one_base_interfaces.xacro"/>
  <xacro:include filename="$(find galbot_one_description)/xacro/ros2_control/galbot_one_arm_interfaces.xacro"/>
  <xacro:include filename="$(find galbot_one_description)/xacro/ros2_control/galbot_one_gripper_interfaces.xacro"/>

  <ros2_control name="galbot_one_system" type="system">
    <hardware>
      <xacro:if value="${'$(arg ros2_control_hardware_type)' == 'gz'}">
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:if value="${'$(arg ros2_control_hardware_type)' == 'mock_components'}">
        <plugin>mock_components/GenericSystem</plugin>
      </xacro:if>
      <xacro:if value="${'$(arg ros2_control_hardware_type)' == 'isaac'}">
        <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
        <param name="joint_commands_topic">/isaac/joint_command</param>
        <param name="joint_states_topic">/isaac/joint_states</param>
      </xacro:if>
    </hardware>

    <xacro:galbot_one_base_interfaces/>
    <xacro:galbot_one_arm_interfaces name="left"/>
    <xacro:galbot_one_arm_interfaces name="right"/>

    <xacro:if value="${'$(arg type)' == 'gripper'}">
      <xacro:galbot_one_gripper_interfaces name="left"/>
      <xacro:galbot_one_gripper_interfaces name="right"/>
    </xacro:if>
  </ros2_control>

  <xacro:arg name="gazebo" default="false"/>
  <xacro:if value="$(arg gazebo)">
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find galbot_one_description)/config/ros2_control/${ros2_control_config_basename}</parameters>
      </plugin>
    </gazebo>
  </xacro:if>
</robot>
