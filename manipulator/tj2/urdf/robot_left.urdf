      <mass value="3.6913"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <!-- Joint 4 -->
  <joint name="left_joint4" type="revolute">
    <parent link="left_link3"/>
    <child link="left_link4"/>
    <origin xyz="0.018 0 0.314" rpy="1.5708 0 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.44346" upper="1.36136" effort="180" velocity="3.08149"/>
