<?xml version="1.0"?>
<robot name="left_arm_robot">

  <!-- Material definitions -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="gray">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <!-- Base Link -->
  <link name="left_base_link">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.15"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1" radius="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Joint 1 -->
  <joint name="left_joint1" type="revolute">
    <parent link="left_base_link"/>
    <child link="left_link1"/>
    <origin xyz="0 0 0.1017" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96706" upper="2.96706" effort="180" velocity="4.0407"/>
  </joint>

  <link name="left_link1">
    <visual>
      <geometry>
        <cylinder length="0.1745" radius="0.06"/>
      </geometry>
      <material name="blue"/>
      <origin xyz="0 0 0.08725" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1745" radius="0.06"/>
      </geometry>
      <origin xyz="0 0 0.08725" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 -0.002084 -0.030418" rpy="0 0 0"/>
      <mass value="4.0407"/>
      <inertia ixx="0.104651" ixy="0" ixz="0" iyy="0.104651" iyz="0" izz="0.104651"/>
    </inertial>
  </link>

  <!-- Joint 2 -->
  <joint name="left_joint2" type="revolute">
    <parent link="left_link1"/>
    <child link="left_link2"/>
    <origin xyz="0 0 0.1745" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="180" velocity="2.77241"/>
  </joint>

  <link name="left_link2">
    <visual>
      <geometry>
        <cylinder length="0.287" radius="0.055"/>
      </geometry>
      <material name="blue"/>
      <origin xyz="0 0 0.1435" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.287" radius="0.055"/>
      </geometry>
      <origin xyz="0 0 0.1435" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="-0.008095 0.151407 -0.045915" rpy="0 0 0"/>
      <mass value="2.77241"/>
      <inertia ixx="0.027234" ixy="-0.002166" ixz="0.0024" iyy="0.036772" iyz="0.011008" izz="0.052656"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="left_joint3" type="revolute">
    <parent link="left_link2"/>
    <child link="left_link3"/>
    <origin xyz="0.287 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96706" upper="2.96706" effort="180" velocity="3.6913"/>
