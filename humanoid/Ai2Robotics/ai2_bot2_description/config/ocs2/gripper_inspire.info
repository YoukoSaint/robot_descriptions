        (0,0)  -0.5         ; body_joint1 [rad/s]
        (1,0)  -0.5         ; body_joint2 [rad/s]
        (2,0)  -0.5         ; body_joint3 [rad/s]
        (3,0)  -0.5         ; body_joint4 [rad/s]
        (4,0)  -1.07         ; left_joint1 [rad/s]
        (5,0)  -1.07         ; left_joint2 [rad/s]
        (6,0)  -1.07         ; left_joint3 [rad/s]
        (7,0)  -1.07         ; left_joint4 [rad/s]
        (8,0)  -1.07         ; left_joint5 [rad/s]
        (9,0)  -1.07         ; left_joint6 [rad/s]
        (10,0) -1.07         ; left_joint7 [rad/s]
        (11,0) -1.07         ; right_joint1 [rad/s]
        (12,0) -1.07         ; right_joint2 [rad/s]
        (13,0) -1.07         ; right_joint3 [rad/s]
        (14,0) -1.07         ; right_joint4 [rad/s]
        (15,0) -1.07         ; right_joint5 [rad/s]
        (16,0) -1.07         ; right_joint6 [rad/s]
        (17,0) -1.07         ; right_joint7 [rad/s]
