<?xml version="1.0" encoding="utf-8"?>
<!-- 
  Body definition for DexForce W1 robot
  Contains ankle, knee, buttock, waist, head links and joints
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	<xacro:macro name="dexforce_w1_body">
		<link name="ankle">
			<inertial>
				<origin xyz="8.0372418e-02 -8.2420334e-06  2.0806937e-02"/>
				<mass value="6.271734"/>
				<inertia ixx="4.0e-02" ixy="-3.6858529e-07" ixz="8.4378843e-03" iyy="1.0944388e-01" iyz="-3.1525774e-03"
								 izz="7.0360182e-02"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Torso/torso1.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Torso/torso1.obj"/>
				</geometry>
			</collision>
		</link>

		<link name="knee">
			<inertial>
				<origin xyz="7.4144729e-02  3.5641805e-05  5.7481550e-03"/>
				<mass value="5.7732119"/>
				<inertia ixx="2.0e-02" ixy="-3.6600899e-03" ixz="2.7064201e-03" iyy="8.0129350e-02" iyz="-1.8650759e-03"
								 izz="6.4174708e-02"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Torso/torso2.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Torso/torso2.obj"/>
				</geometry>
			</collision>
		</link>

		<link name="buttock">
			<inertial>
				<origin xyz="5.2490838e-02  1.2635673e-05  9.2446495e-03"/>
				<mass value="7.4072832"/>
				<inertia ixx="2.0057819e-02" ixy="3.3385889e-06" ixz="3.6102235e-03" iyy="4.1292505e-02" iyz="3.9554651e-06"
								 izz="3.5409712e-02"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Torso/torso3.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Torso/torso3.obj"/>
				</geometry>
			</collision>
		</link>

		<link name="waist">
			<inertial>
				<origin xyz="6.4016818e-03  4.8188781e-04  2.0011730e-01"/>
				<mass value="6.40803"/>
				<inertia ixx="9.4768963e-02" ixy="3.6070706e-04" ixz="1.5765521e-03" iyy="7.8791635e-02" iyz="-7.5017650e-03"
								 izz="3.8690356e-02"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Torso/torso4.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Torso/torso4.obj"/>
				</geometry>
			</collision>
		</link>

		<joint name="body_joint1" type="revolute">
			<origin xyz="0 0 0.292" rpy="1.5707963267948966 0 0"/>
			<parent link="base_link"/>
			<child link="ankle"/>
			<axis xyz="0 0 -1"/>
			<limit lower="-1.5707963267948966" upper="1.5707963267948966" effort="100" velocity="0.8726646259971648"/>
		</joint>
		<joint name="body_joint2" type="revolute">
			<origin xyz="0 0.34 0"/>
			<parent link="ankle"/>
			<child link="knee"/>
			<axis xyz="0 0 -1"/>
			<limit lower="-2.705260340591211" upper="2.705260340591211" effort="100" velocity="1.3089969389957472"/>
		</joint>
		<joint name="body_joint3" type="revolute">
			<origin xyz="0 0.34 0"/>
			<parent link="knee"/>
			<child link="buttock"/>
			<axis xyz="0 0 -1"/>
			<limit lower="-1.9198621771937625" upper="1.5707963267948966" effort="100" velocity="0.8726646259971648"/>
		</joint>
		<joint name="body_joint4" type="revolute">
			<origin xyz="0 0.1578 0" rpy="-1.5707963267948966 0 0"/>
			<parent link="buttock"/>
			<child link="waist"/>
			<axis xyz="0 0 1"/>
			<limit lower="-2.9670597283903604" upper="2.9670597283903604" effort="100" velocity="1.3089969389957472"/>
		</joint>

		<link name="waist_to_neck_connector"/>
		<link name="neck_base"/>

		<link name="neck1">
			<inertial>
				<origin xyz="8.0771079e-05 -4.9617728e-03  5.2251935e-02 "/>
				<mass value="0.9607041"/>
				<inertia ixx="1.76988687535663E-05" ixy="-3.29843265585722E-14" ixz="1.12004314355796E-12"
								 iyy="1.698812924773E-05" iyz="4.19769754584448E-06" izz="1.42153718545556E-05"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Head/head1.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Head/head1.obj"/>
				</geometry>
			</collision>
		</link>

		<link name="neck2">
			<inertial>
				<origin xyz="3.5749562e-02  3.9029998e-02  5.9305750e-03"/>
				<mass value="0.76222648"/>
				<inertia ixx="0.00119162799314456" ixy="0.000139409177964968" ixz="-1.74009535043774E-06"
								 iyy="0.00102931058067242" iyz="-1.913284242482E-06" izz="0.00092225648400233"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Visual/Common/Head/head2.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find dexforce_w1_description)/meshes/Collision/Common/Head/head2.obj"/>
				</geometry>
			</collision>
		</link>

		<link name="eyes"/>

		<joint name="WAIST_TO_NECK_CONNECTOR" type="fixed">
			<origin xyz="0 0 0.308"/>
			<parent link="waist"/>
			<child link="waist_to_neck_connector"/>
		</joint>

		<joint name="NECK_BASE" type="fixed">
			<parent link="waist_to_neck_connector"/>
			<child link="neck_base"/>
		</joint>

		<joint name="head_joint1" type="revolute">
			<parent link="neck_base"/>
			<child link="neck1"/>
			<axis xyz="0 0 1"/>
			<limit lower="-1.5707963267948966" upper="1.5707963267948966" effort="50" velocity="0.8726646259971648"/>
		</joint>

		<joint name="head_joint2" type="revolute">
			<origin xyz="0 0 0.081" rpy="-1.5707963267948966 0 0"/>
			<parent link="neck1"/>
			<child link="neck2"/>
			<axis xyz="0 0 -1"/>
			<limit lower="-0.7853981633974483" upper="0.4363323129985824" effort="50" velocity="0.8726646259971648"/>
		</joint>

		<joint name="EYES" type="fixed">
			<origin xyz="0.085 -0.051 0.0" rpy="2.879 1.5708 0.0"/>
			<parent link="neck2"/>
			<child link="eyes"/>
		</joint>

	</xacro:macro>
</robot>