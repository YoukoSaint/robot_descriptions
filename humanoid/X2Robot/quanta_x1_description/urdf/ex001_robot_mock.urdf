  <ros2_control is_async="true" name="ex001_robot" type="system">
    <hardware>
      <plugin>x2robot_hardware_interface/MockRobotHardwareInterface</plugin>
      <param name="command_topic">/mock_robot_interface/command</param>
      <param name="state_topic">/mock_robot_interface/state</param>
      <param name="use_ipc">1</param>
      <param name="sim_bridge">False</param>
    </hardware>
    <!-- Add head Joint -->
    <joint name="head_yaw_joint"/>
    <joint name="head_pitch_joint"/>
    <!-- Add waist joint -->
    <joint name="lift_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- Add left arm -->
    <joint name="left_arm_joint1">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_arm_joint2">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_arm_joint3">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_arm_joint4">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_arm_joint5">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_arm_joint6">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- Add right arm -->
    <joint name="right_arm_joint1">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <command_interface name="mit_kp"/>
      <command_interface name="mit_kd"/>
      <command_interface name="ctrl_mode"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
