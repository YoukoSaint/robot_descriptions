      <inertia ixx="0.001163" ixy="0.000035" ixz="0.000167" iyy="0.00114" iyz="-0.000232" izz="0.000073"/>
    </inertial>
  </link>

  <!-- Joint 6 -->
  <joint name="left_joint6" type="revolute">
    <parent link="left_link5"/>
