<?xml version="1.0"?>

<robot name="Aloha Split" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find agilex_aloha_description)/xacro/base/ranger_mini.xacro"/>
  <xacro:include filename="$(find piper_description)/xacro/Piper.xacro"/>
  <xacro:include filename="$(find agilex_aloha_description)/xacro/body/split.xacro"/>

  <xacro:Piper name="left"/>
  <xacro:Piper name="right"/>
</robot>
