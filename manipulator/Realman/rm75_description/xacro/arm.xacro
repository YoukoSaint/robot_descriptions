<?xml version="1.0"?>
<robot name="Realman RM75" xmlns:xacro="http://www.ros.org/wiki/xacro">
	<xacro:include filename="$(find rm75_description)/xacro/components/fb75_camera.xacro"/>
	<xacro:macro name="rm75" params="name direction:='' enable_joint3:=true ee_type:='aidal' use_base_link:=true">
		<xacro:property name="prefix" value="${name + '_' if name else ''}"/>
		<xacro:property name="enable_joint3_bool" value="${str(enable_joint3).lower() in ['1', 'true', 'yes', 'on']}"/>
		<xacro:property name="joint_index_offset" value="${0 if enable_joint3_bool else 1}"/>
		<xacro:property name="ee_type_norm" value="${str(ee_type).lower()}"/>
		<xacro:property name="use_base_link_bool" value="${str(use_base_link).lower() in ['1', 'true', 'yes', 'on']}"/>
		<!-- Define constants -->
		<xacro:property name="mesh_path" value="file://$(find rm75_description)/meshes/"/>

		<!-- Macro for visual and collision elements -->
		<xacro:macro name="visual_collision" params="mesh">
			<visual>
				<geometry>
					<mesh filename="${mesh_path}${mesh}"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="${mesh_path}${mesh}"/>
				</geometry>
			</collision>
		</xacro:macro>

		<!-- Decoupled root link for external base mounting -->
		<link name="${prefix}arm_root"/>

		<xacro:if value="${use_base_link_bool}">
			<link name="${prefix}base_link">
				<inertial>
					<origin xyz="0.000433268851866144 3.54527840972405E-05 0.0599427623574736"/>
					<mass value="0.841071174772543"/>
					<inertia
							ixx="0.00172611149818605"
							ixy="2.52724703312125E-06"
							ixz="3.67689528877993E-05"
							iyy="0.00170987425756066"
							iyz="-1.68009023667311E-06"
							izz="0.000904023916742301"/>
				</inertial>
				<xacro:visual_collision mesh="base_link.glb"/>
			</link>

			<joint name="${prefix}base_link_fixed" type="fixed">
				<origin xyz="0 0 0.2405" rpy="-1.5708 0 0"/>
				<parent link="${prefix}base_link"/>
				<child link="${prefix}arm_root"/>
			</joint>
		</xacro:if>
		<link name="${prefix}link1">
			<inertial>
				<origin xyz="0.0251854224372461 1.19160585601655E-08 -0.021107996993288"/>
				<mass value="0.593563458735581"/>
				<inertia
						ixx="0.000561352422092522"
						ixy="9.8019294192418E-09"
						ixz="-0.000211217278563478"
						iyy="0.00126614121202124"
						iyz="1.29510293158304E-08"
						izz="0.0011816817861243"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link1.glb"/>
		</link>
		<link name="${prefix}link2">
			<inertial>
				<origin xyz="2.72859133252335E-07 0.011077753037361 0.0761295106490881"/>
				<mass value="0.432849770310974"/>
				<inertia
						ixx="0.00125838173873093"
						ixy="5.63146579602116E-09"
						ixz="1.33486683063366E-09"
						iyy="0.00122245448121472"
						iyz="0.000279003475762058"
						izz="0.000317474184276672"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link2.glb"/>
		</link>

		<link name="${prefix}link3">
			<inertial>
				<origin xyz="6.84676164566044E-07 0.0273475408308154 -0.0235440119707943"/>
				<mass value="0.431325495678459"/>
				<inertia
						ixx="0.000794332771462568"
						ixy="1.03353218375171E-08"
						ixz="-2.32798826854953E-09"
						iyy="0.000315065343266245"
						iyz="-0.000142620540462618"
						izz="0.000730371131605455"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link3.glb"/>
		</link>

		<link name="${prefix}link4">
			<inertial>
				<origin xyz="5.05312670298932E-06 0.0105690692118619 0.0595925663703773"/>
				<mass value="0.289633681619295"/>
				<inertia
						ixx="0.000637371004484591"
						ixy="-3.86643270900744E-08"
						ixz="7.05261290886955E-08"
						iyy="0.000614178164759844"
						iyz="0.000144610359942128"
						izz="0.000156483880946498"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link4.glb"/>
		</link>
		<link name="${prefix}link5">
			<inertial>
				<origin xyz="1.1551661767744E-06 0.0215394748352686 -0.0180424468598241"/>
				<mass value="0.239419768320061"/>
				<inertia
						ixx="0.000285938919722783"
						ixy="2.21994116852616E-09"
						ixz="3.07101358617598E-09"
						iyy="0.00011988808279186"
						iyz="-4.4236583260078E-05"
						izz="0.000262727540304212"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link5.glb"/>
		</link>
		<link name="${prefix}link6">
			<inertial>
				<origin xyz="3.19794787018954E-06 0.00736804250989373 0.0593808368101291"/>
				<mass value="0.218799761431682"/>
				<inertia
						ixx="0.000350540363914436"
						ixy="-1.7705645712277E-08"
						ixz="3.41781620449632E-08"
						iyy="0.000334482418423991"
						iyz="7.82431228462317E-05"
						izz="0.000104927867487584"/>
			</inertial>
			<xacro:visual_collision mesh="arm/link6.glb"/>
		</link>
		<link name="${prefix}link7">
			<inertial>
				<origin xyz="0.000714238382876259 -0.000396711987952758 -0.0126723660946126"/>
				<mass value="0.0649018034311231"/>
				<inertia
						ixx="2.02766547502765E-05"
						ixy="-1.32505200276848E-06"
						ixz="-2.58450915224912E-08"
						iyy="1.87986725225022E-05"
						iyz="3.39471452123283E-09"
						izz="3.17885459163081E-05"/>
			</inertial>
			<xacro:if value="${ee_type_norm == 'aidal'}">
				<xacro:visual_collision mesh="ee/ee_aidal.glb"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'fb'}">
				<xacro:visual_collision mesh="ee/ee_fb.glb"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'basic'}">
				<xacro:visual_collision mesh="ee/ee_basic.glb"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'fb_camera'}">
				<xacro:visual_collision mesh="ee/ee_fb_camera.glb"/>
			</xacro:if>
		</link>
		<xacro:if value="${ee_type_norm == 'fb_camera'}">
			<xacro:rm75_fb75_camera prefix="${prefix}" parent_link="${prefix}link7"/>
		</xacro:if>

		
		<joint name="${prefix}joint1" type="revolute">
			<parent link="${prefix}arm_root"/>
			<child link="${prefix}link1"/>
			<axis xyz="0 -1 0"/>
			<limit lower="-3.1" upper="3.1" effort="60" velocity="3.14"/>
		</joint>
		<joint name="${prefix}joint2" type="revolute">
			<origin rpy="1.5708 0 0"/>
			<parent link="${prefix}link1"/>
			<child link="${prefix}link2"/>
			<axis xyz="0 1 0"/>
			<limit lower="-2.268" upper="2.268" effort="60" velocity="3.14"/>
		</joint>
		<xacro:if value="${enable_joint3_bool}">
			<joint name="${prefix}joint3" type="revolute">
				<origin xyz="0 0 0.256" rpy="-1.5708 0 0"/>
				<parent link="${prefix}link2"/>
				<child link="${prefix}link3"/>
				<axis xyz="0 -1 0"/>
				<limit lower="-3.1" upper="3.1" effort="30" velocity="3.92"/>
			</joint>
		</xacro:if>
		<xacro:unless value="${enable_joint3_bool}">
			<joint name="${prefix}joint3_fixed" type="fixed">
				<origin xyz="0 0 0.256" rpy="-1.5708 0 0"/>
				<parent link="${prefix}link2"/>
				<child link="${prefix}link3"/>
			</joint>
		</xacro:unless>

		<joint name="${prefix}joint${4 - joint_index_offset}" type="revolute">
			<origin rpy="1.5708 0 0"/>
			<parent link="${prefix}link3"/>
			<child link="${prefix}link4"/>
			<axis xyz="0 1 0"/>
			<limit lower="-2.355" upper="2.355" effort="30" velocity="3.92"/>
		</joint>

		<joint name="${prefix}joint${5 - joint_index_offset}" type="revolute">
			<origin xyz="0 0 0.21" rpy="-1.5708 0 0"/>
			<parent link="${prefix}link4"/>
			<child link="${prefix}link5"/>
			<axis xyz="0 -1 0"/>
			<limit lower="-3.1" upper="3.1" effort="10" velocity="3.92"/>
		</joint>

		<joint name="${prefix}joint${6 - joint_index_offset}" type="revolute">
			<origin rpy="1.5708 0 0"/>
			<parent link="${prefix}link5"/>
			<child link="${prefix}link6"/>
			<axis xyz="0 1 0"/>
			<limit lower="-2.233" upper="2.233" effort="10" velocity="3.92"/>
		</joint>

		<joint name="${prefix}joint${7 - joint_index_offset}" type="revolute">
			<origin xyz="0 0 0.115"/>
			<parent link="${prefix}link6"/>
			<child link="${prefix}link7"/>
			<axis xyz="0 0 1"/>
			<limit lower="-6.28" upper="6.28" effort="10" velocity="3.925"/>
		</joint>

		<!-- End effector link for gripper attachment -->
		<link name="${prefix}ee">
			<xacro:if value="${ee_type_norm == 'aidal'}">
				<xacro:visual_collision mesh="flange/basic.glb"/>
			</xacro:if>
		</link>
		<joint name="${prefix}ee_joint" type="fixed">
			<xacro:if value="${ee_type_norm == 'aidal'}">
				<origin xyz="0 0 0.043"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'basic'}">
				<origin xyz="0 0 0.02905"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'fb'}">
				<origin xyz="0 0 0.046"/>
			</xacro:if>
			<xacro:if value="${ee_type_norm == 'fb_camera'}">
				<origin xyz="0 0 0.0695"/>
			</xacro:if>
			<parent link="${prefix}link7"/>
			<child link="${prefix}ee"/>
		</joint>
	</xacro:macro>
</robot>
