<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="Body">

        <xacro:property name="PI" value="3.1415926535897931"/>

        <link name="lift_link">
            <inertial>
                <origin xyz="0.13956899916103924 0 0.07323798891482189"/>
                <mass value="17.38744536890084"/>
                <inertia ixx="0.187458" ixy="-0.000206" ixz="0.023942" iyy="0.178157" iyz="-0.000153" izz="0.29708"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/lift.obj"/>
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/lift.obj"/>
                </geometry>
            </collision>
        </link>

        <joint name="lift_joint" type="prismatic">
            <origin xyz="-0.032 0 0.233"/>
            <parent link="base_link"/>
            <child link="lift_link"/>
            <axis xyz="0.0 0.0 1.0"/>
            <limit effort="1000" lower="0.0" upper="0.86" velocity="100"/>
        </joint>

        <link name="h_base_link">
            <inertial>
                <origin xyz="-0.0020743076738515215 0 0.024619861716967787"/>
                <mass value="0.9930933606993821"/>
                <inertia ixx="0.000391" ixy="-0.0" ixz="1.7e-05" iyy="0.000452" iyz="0.0" izz="0.000532"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/h_base.obj"/>
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/h_base.obj"/>
                </geometry>
            </collision>
        </link>

        <link name="head_link1">
            <inertial>
                <origin xyz="-1.2166451790474E-08 0.000155101086835956 0.0414775143344981"/>
                <mass value="0.429406588376073"/>
                <inertia
                        ixx="0.00027"
                        ixy="0.00000"
                        ixz="0.00000"
                        iyy="0.00026"
                        iyz="-0.00001"
                        izz="0.00018"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/neck.obj"/>
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/neck.obj"/>
                </geometry>
            </collision>
        </link>

        <link name="head_link2">
            <inertial>
                <origin xyz="0.0145474612596931 0.0229595215513494 0.0787914285814235"/>
                <mass value="1.54420437039843"/>
                <inertia
                        ixx="0.00576"
                        ixy="-0.00007"
                        ixz="0.00018"
                        iyy="0.00477"
                        iyz="0.00015"
                        izz="0.00768"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/head.obj"/>
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="file://$(find arx_lift_description)/meshes/body/head.obj"/>
                </geometry>
            </collision>
        </link>

        <joint name="head_joint1" type="continuous">
            <origin xyz="0.0 0.0 0.046"/>
            <parent link="h_base_link"/>
            <child link="head_link1"/>
            <axis xyz="0.0 0.0 1.0"/>
            <limit effort="100" lower="${-PI/2}" upper="${PI/2}" velocity="100"/>
        </joint>

        <joint name="head_joint2" type="continuous">
            <origin xyz="0.0 -0.025 0.049"/>
            <parent link="head_link1"/>
            <child link="head_link2"/>
            <axis xyz="0.0 -1.0 0.0"/>
            <limit effort="100" lower="${-PI/4}" upper="${PI/4}" velocity="100"/>
        </joint>

        <joint name="h_fixed" type="fixed">
            <parent link="lift_link"/>
            <child link="h_base_link"/>
            <origin xyz="0.258786 0 0.220008"/>
        </joint>

        <link name="head_camera">
            <visual>
                <geometry>
                    <mesh filename="file://$(find sensor_models)/meshes/d405/d405.obj"/>
                </geometry>
            </visual>
        </link>

        <joint name="head_camera_joint" type="fixed">
            <origin xyz="0.095 0.025 0.06"/>
            <parent link="head_link2"/>
            <child link="head_camera"/>
        </joint>


    </xacro:macro>
</robot>