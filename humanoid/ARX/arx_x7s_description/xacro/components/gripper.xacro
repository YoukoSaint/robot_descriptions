<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	<!-- X7S Gripper Macro
		Parameters:
		- name: gripper name prefix (e.g., "left" or "right")
		- direction: direction multiplier (1 for left, -1 for right)
	-->
	<xacro:macro name="Gripper" params="name direction:=1">
		<xacro:property name="prefix" value="${name + '_' if name else ''}"/>
		<xacro:property name="dir" value="${direction}"/>

		<link name="${prefix}gripper_base">
			<inertial>
				<origin xyz="0.0782374674886107 2.27688611500743E-05 0.0203907673011059"/>
				<mass value="0.471847835335863"/>
				<inertia
						ixx="0.00040"
						ixy="0.00000"
						ixz="0.00006"
						iyy="0.00043"
						iyz="0.00000"
						izz="0.00064"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_base.obj"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_base.obj"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}joint7" type="revolute">
			<origin xyz="0.066 ${dir * 0.02725} -0.022"/>
			<parent link="${prefix}wrist"/>
			<child link="${prefix}gripper_base"/>
			<axis xyz="0 0 ${-dir}"/>
			<limit lower="-1.570796" upper="1.570796" effort="100" velocity="100"/>
		</joint>

		<link name="${prefix}gripper_left">
			<inertial>
				<origin xyz="-0.000355222592141713 -0.00782703850949387 -0.00298831676915334"/>
				<mass value="0.0647981743053201"/>
				<inertia
						ixx="0.00002"
						ixy="0.00000"
						ixz="0.00000"
						iyy="0.00003"
						iyz="0.00000"
						izz="0.00003"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_left.obj"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_left.obj"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}gripper_joint" type="prismatic">
			<origin xyz="0.12737 0.024896 0.021756"/>
			<parent link="${prefix}gripper_base"/>
			<child link="${prefix}gripper_left"/>
			<axis xyz="0 1 0"/>
			<limit lower="0" upper="0.044" effort="100" velocity="100"/>
		</joint>

		<link name="${prefix}gripper_right">
			<inertial>
				<origin xyz="-0.000355223470276722 0.00782768741060949 0.00242005652832489"/>
				<mass value="0.0647981725781686"/>
				<inertia
						ixx="0.00002"
						ixy="0.00000"
						ixz="0.00000"
						iyy="0.00003"
						iyz="0.00000"
						izz="0.00003"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_right.obj"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find arx_x7s_description)/meshes/gripper/gripper_right.obj"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}gripper_1" type="prismatic">
			<origin xyz="0.12737 -0.0249 0.021756"/>
			<parent link="${prefix}gripper_base"/>
			<child link="${prefix}gripper_right"/>
			<axis xyz="0 -1 0"/>
			<limit lower="0" upper="0.044" effort="100" velocity="100"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1" offset="0"/>
		</joint>

		<link name="${prefix}eef"/>
		<joint name="${prefix}eef_joint" type="fixed">
			<origin xyz="0.18737 0 0.021756"/>
			<parent link="${prefix}gripper_base"/>
			<child link="${prefix}eef"/>
		</joint>
	</xacro:macro>
</robot>
