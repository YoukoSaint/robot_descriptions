<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="Body">
    <link name="body">
      <inertial>
        <origin xyz="-0.000779578835400224 0.053760645280584 0.220464314501233"/>
        <mass value="3.01262653552798"/>
        <inertia
            ixx="0.03987"
            ixy="0.00000"
            ixz="-0.00003"
            iyy="0.03461"
            iyz="0.00039"
            izz="0.00967"/>
      </inertial>
      <visual>
        <geometry>
          <mesh
              filename="file://$(find arx_x7s_description)/meshes/base/body.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/base/body.obj"/>
        </geometry>
      </collision>
    </link>

    <joint name="waist_joint" type="revolute">
      <origin xyz="0.066 -0.0546 -0.06"/>
      <parent link="lift"/>
      <child link="body"/>
      <axis xyz="0 1 0"/>
      <limit lower="0" upper="1.57" effort="100" velocity="5"/>
    </joint>

    <link name="neck">
      <inertial>
        <origin xyz="-1.2166451790474E-08 0.000155101086835956 0.0414775143344981"/>
        <mass value="0.429406588376073"/>
        <inertia
            ixx="0.00027"
            ixy="0.00000"
            ixz="0.00000"
            iyy="0.00026"
            iyz="-0.00001"
            izz="0.00018"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/body/neck.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/body/neck.obj"/>
        </geometry>
      </collision>
    </link>

    <joint name="head_joint1" type="revolute">
      <origin xyz="0 0.0544 0.356"/>
      <parent link="body"/>
      <child link="neck"/>
      <axis xyz="0 0 1"/>
      <limit effort="100" lower="-1.570796" upper="1.570796" velocity="100"/>
    </joint>

    <link name="head">
      <inertial>
        <origin xyz="0.0145474612596931 0.0229595215513494 0.0787914285814235"/>
        <mass value="1.54420437039843"/>
        <inertia
            ixx="0.00576"
            ixy="-0.00007"
            ixz="0.00018"
            iyy="0.00477"
            iyz="0.00015"
            izz="0.00768"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/body/head.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_lift_description)/meshes/body/head.obj"/>
        </geometry>
      </collision>
    </link>

    <joint name="head_joint2" type="revolute">
      <origin xyz="0 -0.025 0.049"/>
      <parent link="neck"/>
      <child link="head"/>
      <axis xyz="0 -1 0"/>
      <limit lower="-0.785398" upper="0.785398" effort="100" velocity="5"/>
    </joint>

    <link name="head_camera">
      <visual>
        <geometry>
          <mesh filename="file://$(find sensor_models)/meshes/d405/d405.obj"/>
        </geometry>
      </visual>
    </link>

    <joint name="head_camera_joint" type="fixed">
      <origin xyz="0.095 0.025 0.06"/>
      <parent link="head"/>
      <child link="head_camera"/>
    </joint>
  </xacro:macro>
</robot>

