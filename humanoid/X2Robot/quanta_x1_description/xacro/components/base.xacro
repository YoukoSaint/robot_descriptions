		</link>

		<joint name="left_front_ultrasonic_joint" type="fixed">
			<origin rpy="0 -0.2618 -0.2618" xyz="0.2612 0.172 0.17811"/>
			<parent link="chassis_base_link"/>
			<child link="left_front_ultrasonic_link"/>
		</joint>

		<link name="left_rear_ultrasonic_link">
			<inertial>
				<origin xyz="-0.013843472 1.69864122767649e-14 -0.000113947"/>
				<mass value="0.00892178440560658"/>
				<inertia ixx="9.74741018449214e-07" ixy="8.95274120578393e-19" ixz="1.73818627801905e-08"
								 iyy="5.91407456386544e-07" iyz="-8.27e-18" izz="1.09468928053872e-06"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/ultrasonic/ultrasonic_01.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="left_rear_ultrasonic_joint" type="fixed">
			<origin rpy="0 -0.2618 -2.8274" xyz="-0.26102 0.17142 0.21811"/>
			<parent link="chassis_base_link"/>
			<child link="left_rear_ultrasonic_link"/>
		</joint>

		<link name="right_front_ultrasonic_link">
			<inertial>
				<origin xyz="-0.013843472 1.69586567011493e-14 -0.000113947"/>
				<mass value="0.00892178440560675"/>
				<inertia ixx="9.74741018449211e-07" ixy="8.39819932312838e-19" ixz="1.73818627801337e-08"
								 iyy="5.91407456386574e-07" iyz="-8.29e-18" izz="1.09468928053873e-06"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/ultrasonic/ultrasonic_01.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="right_front_ultrasonic_joint" type="fixed">
			<origin rpy="0 -0.2618 0.2618" xyz="0.2612 -0.172 0.17811"/>
			<parent link="chassis_base_link"/>
			<child link="right_front_ultrasonic_link"/>
		</joint>

		<link name="right_rear_ultrasonic_link">
			<inertial>
				<origin xyz="-0.013843472 1.01585406753202e-14 -0.000113947"/>
				<mass value="0.00892178440560984"/>
				<inertia ixx="9.74741018449204e-07" ixy="-7.59e-20" ixz="1.73818627794188e-08" iyy="5.91407456386667e-07"
								 iyz="-8.26e-18" izz="1.09468928053869e-06"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/ultrasonic/ultrasonic_01.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="right_rear_ultrasonic_joint" type="fixed">
			<origin rpy="0 -0.2618 2.8274" xyz="-0.26102 -0.17142 0.21811"/>
			<parent link="chassis_base_link"/>
			<child link="right_rear_ultrasonic_link"/>
		</joint>

		<link name="2d_laser_link"/>

		<joint name="2d_laser_link_connector" type="fixed">
			<origin xyz="0.235 0 0.219"/>
			<parent link="chassis_base_link"/>
			<child link="2d_laser_link"/>
		</joint>

		<link name="3d_laser_link"/>

		<joint name="3d_laser_link_connector" type="fixed">
			<origin xyz="0.235 0 0.21"/>
			<parent link="chassis_base_link"/>
			<child link="3d_laser_link"/>
		</joint>

		<link name="base_front_camera_frame_link">
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/orbbec/Dabai_Max.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="base_front_camera_connector" type="fixed">
			<origin rpy="0 -0.34907 0" xyz="0.273 0 0.158"/>
			<parent link="chassis_base_link"/>
			<child link="base_front_camera_frame_link"/>
		</joint>

		<link name="left_up_camera_base_link">
			<inertial>
				<origin xyz="0.00441611097656924 -1.67e-16 -0.000268164"/>
				<mass value="0.00469862275446301"/>
				<inertia ixx="3.85215034520352e-07" ixy="-1.22e-20" ixz="9.47029983048071e-09" iyy="3.32214139196315e-07"
								 iyz="-4.04e-22" izz="3.17754525441374e-07"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/usb_camera/camera_01.glb"/>
				</geometry>
			</visual>
		</link>

		<joint name="left_up_camera_base_joint" type="fixed">
			<origin rpy="-2.35619 0 -0.34909" xyz="-0.022392 0.1299 1.4414"/>
			<parent link="chassis_base_link"/>
			<child link="left_up_camera_base_link"/>
		</joint>

		<link name="right_up_camera_base_link">
			<inertial>
				<origin xyz="0.00441611097656958 -2.78e-17 -0.000268164"/>
				<mass value="0.00469862275446298"/>
				<inertia ixx="3.85215034520349e-07" ixy="-1.21e-20" ixz="9.47029983048099e-09" iyy="3.32214139196311e-07"
								 iyz="-1.39e-22" izz="3.1775452544137e-07"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/usb_camera/camera_01.glb"/>
				</geometry>
			</visual>
		</link>
		<joint name="right_up_camera_base_joint" type="fixed">
			<origin rpy="-2.3562 0 -2.7925" xyz="-0.022392 -0.1299 1.4414"/>
			<parent link="chassis_base_link"/>
			<child link="right_up_camera_base_link"/>
		</joint>

		<link name="imu_link"/>
		<joint name="imu_joint" type="fixed">
			<origin xyz="0.16798 0.00009 0.2076"/>
			<parent link="chassis_base_link"/>
			<child link="imu_link"/>
			
		</joint>
		<xacro:QuantaX1BaseRos2Control/>

		<link name="2d_laser_base">
			<inertial>
				<origin xyz="0 0 0.03"/>
				<mass value="0.0145098733371325"/>
				<inertia ixx="1.31154092579587E-05" ixy="2.30174744915791E-07" ixz="-1.33602201591692E-09"
								 iyy="1.37294183645858E-06" iyz="-1.54099158222408E-08" izz="1.23744229267791E-05"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find sensor_models)/meshes/2d_lidars/waveshare_STL-27L.glb"/>
				</geometry>
			</visual>
		</link>
		
		<joint name="2d_laser_joint" type="fixed">
			<origin xyz="0 0 0.027"/>
			<parent link="2d_laser_base"/>
			<child link="2d_laser"/>
		</joint>

		<link name="2d_laser"/>

		<joint name="laser_connector" type="fixed">
			<parent link="2d_laser_link"/>
			<child link="2d_laser_base"/>
		</joint>

		<xacro:QuantaX1Swivel prefix="fl" x="0.212205" y="0.172203" z="0.061972"/>
		<xacro:QuantaX1Swivel prefix="fr" x="0.212205" y="-0.172203" z="0.061972"/>
		<xacro:QuantaX1Swivel prefix="rl" x="-0.1878" y="0.172203" z="0.061972"/>
		<xacro:QuantaX1Swivel prefix="rr" x="-0.1878" y="-0.172203" z="0.061972"/>

	</xacro:macro>
</robot>
