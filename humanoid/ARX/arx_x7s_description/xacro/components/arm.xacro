<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="PI" value="3.1415926535897931"/>
  
  <!-- X7S Arm Macro
    Parameters:
    - name: arm name prefix (e.g., "left" or "right")
    - direction: direction multiplier (1 for left, -1 for right)
  -->
  <xacro:macro name="Arm" params="name direction:=1">
    <xacro:property name="prefix" value="${name + '_' if name else ''}"/>
    <xacro:property name="dir" value="${direction}"/>

    <!-- Calculate positions and orientations based on direction -->
    <!-- Left arm: mount at y=0.1424, right arm: mount at y=-0.0336 -->
    <!-- Using interpolation: left_y = 0.1424, right_y = -0.0336 -->
    <!-- Average: (0.1424 + (-0.0336)) / 2 = 0.0544, difference: 0.1424 - 0.0544 = 0.088 -->
    <xacro:property name="mount_y" value="${0.0544 + dir * 0.088}"/>
    <xacro:property name="shoulder_y" value="${dir * 0.063}"/>
    <xacro:property name="elbow_y" value="${-dir * 0.02725}"/>
    <xacro:property name="elbow_roll_y" value="${dir * 0.02725}"/>
    <xacro:property name="wrist_y" value="${-dir * 0.02725}"/>
    <xacro:property name="wrist_yaw_y" value="${dir * 0.02725}"/>

    <link name="${prefix}mount">
      <inertial>
        <origin xyz="0.0203118776657915 ${dir * 0.0282074621926044} -0.000172803675324795"/>
        <mass value="0.131891884746085"/>
        <inertia
            ixx="0.00012"
            ixy="${dir * 0.00004}"
            ixz="0.00000"
            iyy="0.00009"
            iyz="0.00000"
            izz="0.00014"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/base.obj" scale="1 ${dir} 1"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/base.obj" scale="1 ${dir} 1"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint1" type="revolute">
      <origin xyz="0 ${mount_y} 0.28"/>
      <parent link="body"/>
      <child link="${prefix}mount"/>
      <axis xyz="0 -1 0"/>
      <limit lower="-0.523599" upper="3.141593" effort="100" velocity="${PI}"/>
    </joint>

    <link name="${prefix}shoulder">
      <inertial>
        <origin xyz="-0.0244518842072319 ${dir * 0.00440119803297737} -0.0251861647177716"/>
        <mass value="1.03161675931573"/>
        <inertia
            ixx="0.00167"
            ixy="${dir * 0.00003}"
            ixz="0.00007"
            iyy="0.00166"
            iyz="${dir * 0.00005}"
            izz="0.00088"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link1.obj" scale="1 ${dir} 1"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link1.obj" scale="1 ${dir} 1"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint2" type="revolute">
      <origin xyz="0.02725 ${shoulder_y} 0"/>
      <parent link="${prefix}mount"/>
      <child link="${prefix}shoulder"/>
      <axis xyz="${dir} 0 0"/>
      <limit lower="-0.436332" upper="1.570796" effort="100" velocity="${PI}"/>
    </joint>

    <link name="${prefix}upper_arm">
      <inertial>
        <origin xyz="0.000827778295739684 ${-dir * 0.00148365067233044} -0.105295191761956"/>
        <mass value="0.736099125577072"/>
        <inertia
            ixx="0.00229"
            ixy="0.00000"
            ixz="0.00009"
            iyy="0.00230"
            iyz="${dir * 0.00004}"
            izz="0.00060"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link2.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link2.obj"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint3" type="revolute">
      <origin xyz="-0.02725 0 -0.0865"/>
      <parent link="${prefix}shoulder"/>
      <child link="${prefix}upper_arm"/>
      <axis xyz="0 0 ${-dir}"/>
      <limit lower="-1.570796" upper="1.570796" effort="100" velocity="${PI}"/>
    </joint>

    <link name="${prefix}elbow">
      <inertial>
        <origin xyz="0.0593724453089232 ${dir * 0.0253235620813382} -0.0125969681001941"/>
        <mass value="0.487506795308259"/>
        <inertia
            ixx="0.00040"
            ixy="${dir * 0.00003}"
            ixz="-0.00007"
            iyy="0.00055"
            iyz="${-dir * 0.00001}"
            izz="0.00069"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link3.obj" scale="1 ${dir} 1"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link3.obj" scale="1 ${dir} 1"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint4" type="revolute">
      <origin xyz="0 ${elbow_y} -0.1435"/>
      <parent link="${prefix}upper_arm"/>
      <child link="${prefix}elbow"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.785398" upper="1.570796" effort="100" velocity="${PI}"/>
    </joint>

    <link name="${prefix}forearm">
      <inertial>
        <origin xyz="0.0458969495196738 ${-dir * 0.000535552755431795} -9.66305755581987E-05"/>
        <mass value="0.487431771518004"/>
        <inertia
            ixx="0.00024"
            ixy="0.00000"
            ixz="0.00000"
            iyy="0.00027"
            iyz="0.00000"
            izz="0.00029"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link4.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link4.obj" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint5" type="revolute">
      <origin xyz="0.0945 ${elbow_roll_y} -0.015"/>
      <parent link="${prefix}elbow"/>
      <child link="${prefix}forearm"/>
      <axis xyz="1 0 0"/>
      <limit lower="-2.792527" upper="2.792527" effort="100" velocity="${PI}"/>
    </joint>

    <link name="${prefix}wrist">
      <inertial>
        <origin xyz="0.0575036493913677 ${dir * 0.0264951119112793} 0.00135889493052876"/>
        <mass value="0.432944265521347"/>
        <inertia
            ixx="0.00025"
            ixy="${dir * 0.00002}"
            ixz="-0.00002"
            iyy="0.00033"
            iyz="0.00000"
            izz="0.00041"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link5.obj" scale="1 ${dir} 1"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/arm/link5.obj" scale="1 ${dir} 1"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint6" type="revolute">
      <origin xyz="0.05 ${wrist_y} 0"/>
      <parent link="${prefix}forearm"/>
      <child link="${prefix}wrist"/>
      <axis xyz="0 -1 0"/>
      <limit lower="-0.785398" upper="1.570796" effort="100" velocity="${PI}"/>
    </joint>

  </xacro:macro>
</robot>
