<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	<xacro:property name="collider_type" value="$(arg collider)"/>

	<!-- mount_rpy defines gripper_base_link frame orientation relative to flange_mount_link. -->
	<xacro:macro name="Gripper" params="name">
		<xacro:property name="prefix" value="${name + '_' if name else ''}"/>

		<link name="${prefix}gripper_base"/>
		<joint name="${prefix}gripper_base_joint" type="fixed">
			<origin rpy="${PI/2}  ${PI/2}  0"/>
			<parent link="${prefix}gripper_base"/>
			<child link="${prefix}gripper_base_link"/>
		</joint>

		<link name="${prefix}gripper_base_link">
			<inertial>
				<origin xyz="0.0875969515032359 -0.000593766922509439 -0.000273353044587243"/>
				<mass value="0.229646651659589"/>
				<inertia ixx="8.60029243295527E-05" ixy="2.00063024143341E-06" ixz="2.85398505671959E-06"
								 iyy="7.73254340691918E-05" iyz="-1.0856442426917E-07" izz="9.78281466602487E-05"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/base.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'simple'}">
				<collision>
					<origin xyz="-0.1 0 0"/>
					<geometry>
						<box size="0.18000 0.047000 0.067000"/>
					</geometry>
				</collision>
			</xacro:if>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/base.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<link name="${prefix}gripper_l1_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link1.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link1.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<!-- Main driven finger joint (Astribot-style: *_gripper_joint) -->
		<joint name="${prefix}gripper_joint" type="revolute">
			<origin xyz="-0.121835 0 0.02"/>
			<parent link="${prefix}gripper_base_link"/>
			<child link="${prefix}gripper_l1_link"/>
			<axis xyz="0 1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
		</joint>

		<link name="${prefix}gripper_l2_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link2.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link2.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_l2_joint" type="revolute">
			<origin xyz="-0.1368 0 0.01"/>
			<parent link="${prefix}gripper_base_link"/>
			<child link="${prefix}gripper_l2_link"/>
			<axis xyz="0 1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1.0"/>
		</joint>

		<link name="${prefix}gripper_l3_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link3.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link3.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>
		<joint name="${prefix}gripper_l3_joint" type="revolute">
			<origin xyz="-0.064985 0 0.00125"/>
			<parent link="${prefix}gripper_l1_link"/>
			<child link="${prefix}gripper_l3_link"/>
			<axis xyz="0 -1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1.0"/>
		</joint>

		<link name="${prefix}gripper_l4_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link4.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link4.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_l4_joint" type="fixed">
			<parent link="${prefix}gripper_l3_link"/>
			<child link="${prefix}gripper_l4_link"/>
		</joint>
		<link name="${prefix}gripper_l5_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link5.glb"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link5.glb"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_l5_joint" type="fixed">
			<parent link="${prefix}gripper_l3_link"/>
			<child link="${prefix}gripper_l5_link"/>
		</joint>

		<link name="${prefix}gripper_r1_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link1.glb" scale="1 1 -1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link1.glb" scale="1 1 -1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_r1_joint" type="revolute">
			<origin xyz="-0.121835 0 -0.02"/>
			<parent link="${prefix}gripper_base_link"/>
			<child link="${prefix}gripper_r1_link"/>
			<axis xyz="0 -1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1.0"/>
		</joint>

		<link name="${prefix}gripper_r2_link">
			<inertial>
				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link2.glb" scale="1 1 -1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link2.glb" scale="1 1 -1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_r2_joint" type="revolute">
			<origin xyz="-0.1368 0 -0.01"/>
			<parent link="${prefix}gripper_base_link"/>
			<child link="${prefix}gripper_r2_link"/>
			<axis xyz="0 -1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1.0"/>
		</joint>

		<link name="${prefix}gripper_r3_link">
			<inertial>

				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>

				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link3.glb" scale="1 1 -1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link3.glb" scale="1 1 -1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>

		<joint name="${prefix}gripper_r3_joint" type="revolute">
			<origin xyz="-0.064985 0 -0.00125"/>
			<parent link="${prefix}gripper_r1_link"/>
			<child link="${prefix}gripper_r3_link"/>
			<axis xyz="0 1 0"/>
			<limit effort="2" lower="0" upper="1" velocity="3"/>
			<mimic joint="${prefix}gripper_joint" multiplier="1.0"/>
		</joint>

		<link name="${prefix}gripper_r4_link">
			<inertial>

				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link4.glb" scale="1 1 -1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link4.glb" scale="1 1 -1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>
		<joint name="${prefix}gripper_r4_joint" type="fixed">

			<parent link="${prefix}gripper_r3_link"/>
			<child link="${prefix}gripper_r4_link"/>
		</joint>

		<link name="${prefix}gripper_r5_link">
			<inertial>

				<mass value="0.01"/>
				<inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link5.glb" scale="1 1 -1"/>
				</geometry>
			</visual>
			<xacro:if value="${collider_type == 'convex'}">
				<collision>
					<geometry>
						<mesh filename="file://$(find galbot_one_description)/meshes/gripper_hitbot/link5.glb" scale="1 1 -1"/>
					</geometry>
				</collision>
			</xacro:if>
		</link>
		<joint name="${prefix}gripper_r5_joint" type="fixed">

			<parent link="${prefix}gripper_r3_link"/>
			<child link="${prefix}gripper_r5_link"/>
		</joint>

		<link name="${prefix}gripper_tcp_link"/>
		<joint name="${prefix}tcp_joint" type="fixed">
			<origin xyz="0 0 0.21579"/>
			<parent link="${prefix}gripper_base"/>
			<child link="${prefix}gripper_tcp_link"/>
		</joint>
	</xacro:macro>
</robot>
