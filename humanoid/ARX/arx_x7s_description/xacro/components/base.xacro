<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="Base"  params="enable_wheel_joints:='true'">
    <link name="base_link">
      <inertial>
        <origin xyz="-0.061403 0.00062999 0.18169"/>
        <mass value="27.286"/>
        <inertia
            ixx="1.61101"
            ixy="0.00464"
            ixz="-0.16195"
            iyy="1.99174"
            iyz="0.00823"
            izz="1.07279"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/base/base_link.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/base/base_link.obj"/>
        </geometry>
      </collision>
    </link>

    <link name="lift">
      <inertial>
        <origin xyz="-0.010805 -0.00069779 -0.059694"/>
        <mass value="6.205"/>
        <inertia
            ixx="0.01994"
            ixy="-0.00008"
            ixz="-0.00198"
            iyy="0.06039"
            iyz="-0.00016"
            izz="0.06721"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/base/lift.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find arx_x7s_description)/meshes/base/lift.obj"/>
        </geometry>
      </collision>
    </link>

    <joint name="lift_joint" type="prismatic">
      <origin xyz="0.096 0 0.31"/>
      <parent link="base_link"/>
      <child link="lift"/>
      <axis xyz="0 0 1"/>
      <limit lower="0" upper="0.54" effort="100" velocity="5"/>
    </joint>

    <xacro:include filename="$(find arx_lift_description)/xacro/components/wheel.xacro"/>
    <!-- 根据enable_wheel_joints参数决定使用轮子宏还是空link -->
    <xacro:if value="${enable_wheel_joints}">
      <!-- 启用轮子关节时：使用空link -->
      <link name="wheel_1"/>
      <link name="wheel_2"/>
      <link name="wheel_3"/>
      <link name="wheel_4"/>
    </xacro:if>
    <xacro:unless value="${enable_wheel_joints}">
      <!-- 不启用轮子关节时：使用轮子宏创建完整的轮子link（不包含被动轮） -->
      <xacro:wheel wheel_name="wheel_1" enable_passive_wheels="false"/>
      <xacro:wheel wheel_name="wheel_2" enable_passive_wheels="false"/>
      <xacro:wheel wheel_name="wheel_3" enable_passive_wheels="false"/>
      <xacro:wheel wheel_name="wheel_4" enable_passive_wheels="false"/>
    </xacro:unless>

    <xacro:property name="wheel_joint_type" value="fixed"/>
    <xacro:if value="${enable_wheel_joints}">
      <xacro:property name="wheel_joint_type" value="continuous"/>
    </xacro:if>

    <!-- 轮子关节定义 -->
    <joint name="wheel1_joint" type="${wheel_joint_type}">
      <origin xyz="0.21 0.17 0.025" rpy="0.0 0.0 ${-3*PI/4}"/>
      <parent link="base_link"/>
      <child link="wheel_1"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

    <joint name="wheel2_joint" type="${wheel_joint_type}">
      <origin xyz="-0.21 0.17 0.025" rpy="0.0 0.0 ${-PI/4}"/>
      <parent link="base_link"/>
      <child link="wheel_2"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

    <joint name="wheel3_joint" type="${wheel_joint_type}">
      <origin xyz="-0.21 -0.17 0.025" rpy="0.0 0.0 ${PI/4}"/>
      <parent link="base_link"/>
      <child link="wheel_3"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

    <joint name="wheel4_joint" type="${wheel_joint_type}">
      <origin xyz="0.21 -0.17 0.025" rpy="0.0 0.0 ${3*PI/4}"/>
      <parent link="base_link"/>
      <child link="wheel_4"/>
      <xacro:if value="${enable_wheel_joints}">
        <axis xyz="1 0 0"/>
      </xacro:if>
    </joint>

  </xacro:macro>
</robot>

