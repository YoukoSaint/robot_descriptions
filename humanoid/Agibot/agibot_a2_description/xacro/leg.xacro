<?xml version="1.0" encoding="utf-8"?>
<robot name="a2_leg" xmlns:xacro="http://www.ros.org/wiki/xacro">

	<!-- A2 Leg Macro
		Parameters:
		- name: leg name prefix (e.g., "left" or "right")
		- direction: direction multiplier (1 for left, -1 for right)
		- joint_idx_offset: joint index offset (1 for left, 7 for right)
		- parent_link: parent link name (usually "base_link")
		- hip_roll_origin_y: y position for hip_roll joint origin (0.105 for left, -0.105 for right)
	-->
	<xacro:macro name="A2Leg" params="name direction:=1 joint_idx_offset:=1 parent_link hip_roll_origin_y">
		<xacro:property name="prefix" value="${name + '_' if name else ''}"/>
		<xacro:property name="dir" value="${direction}"/>
		<xacro:property name="idx_base" value="${joint_idx_offset}"/>

		<!-- Hip roll -->
		<link name="${prefix}hip_roll">
			<inertial>
				<origin xyz="${dir*0.00011252} ${dir*0.02130615} -0.07465143"/>
				<mass value="2.39059365"/>
				<inertia ixx="0.00381223" iyy="0.00368166" izz="0.00334373" ixy="${-dir*0.00000253}" ixz="${dir*0.00000433}" iyz="0.00019809"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/hip_roll.obj"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/collision/hip_roll.stl"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}hip_roll" type="revolute">
			<origin xyz="-0.0808 ${hip_roll_origin_y} -0.0652" rpy="0.7854 0 1.5708"/>
			<parent link="${parent_link}"/>
			<child link="${prefix}hip_roll"/>
			<axis xyz="0 0 1"/>
			<limit lower="-0.698" upper="0.698" effort="120" velocity="12"/>
		</joint>

		<!-- Hip yaw -->
		<link name="${prefix}hip_yaw">
			<inertial>
				<origin xyz="-0.00012288 ${dir*0.01576460} 0.10828703"/>
				<mass value="3.79911511"/>
				<inertia ixx="0.00941292" iyy="0.01442888" izz="0.00698406" ixy="${dir*0.00000766}" ixz="0.00000238" iyz="${-dir*0.00055185}"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/hip_yaw.obj" scale="1 ${direction} 1"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/collision/hip_yaw.stl" scale="1 ${direction} 1"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}hip_yaw" type="revolute">
			<origin xyz="0 -0.017 -0.0682" rpy="1.5708 -1.5708 0"/>
			<parent link="${prefix}hip_roll"/>
			<child link="${prefix}hip_yaw"/>
			<axis xyz="0 0 1"/>
			<limit lower="-1.57" upper="1.57" effort="120" velocity="12"/>
		</joint>

		<!-- Hip pitch -->
		<link name="${prefix}hip_pitch">
			<inertial>
				<origin xyz="-0.06943423 0.00469099 ${dir*0.02228242}"/>
				<mass value="5.92461880"/>
				<inertia ixx="0.01406779" iyy="0.08875802" izz="0.09356940" ixy="0.00370132" ixz="${-dir*0.00808512}" iyz="${dir*0.00067639}"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/hip_pitch.obj" scale="1 1 ${direction}"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/collision/hip_pitch.stl" scale="1 1 ${direction}"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}hip_pitch" type="revolute">
			<origin xyz="0 ${-dir*0.020} 0.1205" rpy="1.5708 0.7854 0"/>
			<parent link="${prefix}hip_yaw"/>
			<child link="${prefix}hip_pitch"/>
			<axis xyz="0 0 1"/>
			<limit lower="-1.919862144" upper="0.78539815" effort="140" velocity="12"/>
		</joint>

		<!-- Tarsus -->
		<link name="${prefix}tarsus">
			<inertial>
				<origin xyz="-0.17711952 0.00417209 ${dir*0.00013325}"/>
				<mass value="3.02166726"/>
				<inertia ixx="0.00286094" iyy="0.02537518" izz="0.02674320" ixy="-0.00112212" ixz="${dir*0.00004708}" iyz="${dir*0.00001928}"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/tarsus.obj" scale="1 1 ${direction}"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/collision/tarsus.stl" scale="1 1 ${direction}"/>
				</geometry>
			</collision>
		</link>

		<joint name="${prefix}tarsus" type="revolute">
			<origin xyz="-0.34 0 0"/>
			<parent link="${prefix}hip_pitch"/>
			<child link="${prefix}tarsus"/>
			<axis xyz="0 0 1"/>
			<limit lower="-0.087266461" upper="2.443460911" effort="140" velocity="12"/>
		</joint>

		<!-- Toe pitch -->
		<link name="${prefix}toe_pitch">
			<inertial>
				<mass value="0.08772028"/>
				<inertia ixx="0.00001572" iyy="0.00001128" izz="0.00001148" ixy="0.0" ixz="0.0" iyz="0.0"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/toe_pitch.obj"/>
				</geometry>
			</visual>
		</link>

		<joint name="idx${idx_base+4}_${prefix}toe_pitch" type="revolute">
			<origin xyz="-0.377 0 0"/>
			<parent link="${prefix}tarsus"/>
			<child link="${prefix}toe_pitch"/>
			<axis xyz="0 0 1"/>
			<limit lower="-1.047197533" upper="0.523598767" effort="50" velocity="12"/>
		</joint>

		<!-- Toe roll -->
		<link name="${prefix}toe_roll">
			<inertial>
				<origin xyz="-0.03898340 ${dir*0.00002335} 0.03167314"/>
				<mass value="1.21058213"/>
				<inertia ixx="0.00701152" iyy="0.00653210" izz="0.00112114" ixy="${-dir*0.00000021}" ixz="0.00015476" iyz="${-dir*0.00000270}"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/visual/toe_roll.obj"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="file://$(find agibot_a2_description)/meshes/leg/collision/toe_roll.stl"/>
				</geometry>
			</collision>
		</link>

		<joint name="idx${idx_base+5}_${prefix}toe_roll" type="revolute">
			<origin xyz="0 0 0" rpy="-1.5707963 0 0"/>
			<parent link="${prefix}toe_pitch"/>
			<child link="${prefix}toe_roll"/>
			<axis xyz="0 0 1"/>
			<limit lower="-0.488692182" upper="0.488692182" effort="50" velocity="12"/>
		</joint>

	</xacro:macro>

</robot>

