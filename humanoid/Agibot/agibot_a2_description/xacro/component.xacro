<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    Complete Robot Description for Agibot G1                                     | -->
<!-- |    This file includes the base robot structure and both arms                    | -->
<!-- =================================================================================== -->
<robot name="LeftArm" xmlns:xacro="http://www.ros.org/wiki/xacro">

	<xacro:arg name="type" default="left"/>

	<xacro:if value="${'$(arg type)' == 'left'}">
		<link name="base_link"/>
		<xacro:include filename="$(find agibot_a2_description)/xacro/arm.xacro"/>
		<xacro:A2Arm name="left" direction="1" joint_idx_offset="13"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'right'}">
		<link name="base_link"/>
		<xacro:include filename="$(find agibot_a2_description)/xacro/arm.xacro"/>
		<xacro:A2Arm name="right" direction="-1" joint_idx_offset="20"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'base'}">
		<xacro:include filename="$(find agibot_g1_description)/xacro/g1_base.xacro"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'left_hand'}">
		<link name="base_link"/>
		<!-- Virtual parent link for hand connection -->
		<link name="left_arm_link07"/>
		<joint name="left_arm_link07_fixed" type="fixed">
			<parent link="base_link"/>
			<child link="left_arm_link07"/>
		</joint>
		<xacro:include filename="$(find agibot_a2_description)/xacro/hand.xacro"/>
		<xacro:A2Hand name="left" direction="1" parent_link="left_arm_link07"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'right_hand'}">
		<link name="base_link"/>
		<!-- Virtual parent link for hand connection -->
		<link name="right_arm_link07"/>
		<joint name="right_arm_link07_fixed" type="fixed">
			<parent link="base_link"/>
			<child link="right_arm_link07"/>
		</joint>
		<xacro:include filename="$(find agibot_a2_description)/xacro/hand.xacro"/>
		<xacro:A2Hand name="right" direction="-1" parent_link="right_arm_link07"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'left_leg'}">
		<link name="base_link"/>
		<xacro:include filename="$(find agibot_a2_description)/xacro/leg.xacro"/>
		<xacro:A2Leg name="left" direction="1" joint_idx_offset="1" parent_link="base_link" hip_roll_origin_y="0.105"/>
	</xacro:if>

	<xacro:if value="${'$(arg type)' == 'right_leg'}">
		<link name="base_link"/>
		<xacro:include filename="$(find agibot_a2_description)/xacro/leg.xacro"/>
		<xacro:A2Leg name="right" direction="-1" joint_idx_offset="7" parent_link="base_link" hip_roll_origin_y="-0.105"/>
	</xacro:if>
</robot>
